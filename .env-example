# ---- Postgres ----
POSTGRES_DB=postgres_db
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
POSTGRES_HOST=local_database

# ---- App ----
DEBUG=true

# ---- JWT ----
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256

# ---- Sentry (leave empty to disable) ----
SENTRY=

# ---- Frontend -> backend ----
BACKEND_API=http://backend_api:9999/api/

# ---- RabbitMQ ----
RMQ_HOST=your-rabbitmq-host
RMQ_PORT=5671
RMQ_VIRTUAL_HOST=your_vhost
RMQ_USER=your_user
RMQ_PASSWORD=change_me

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_your_key

# ---- S3 / object storage (e.g. Cloudflare R2) ----
ACCESS_KEY=your_access_key
SECRET_KEY=your_secret_key
BUCKET_NAME=your_bucket
ENDPOINT=https://your-endpoint
PUBLIC_URL=https://your-public-url

# ---- Email / SMTP (notification service) ----
SMTP_SERVER=smtp.ukr.net
USER=your_email@ukr.net
TOKEN_UKR_NET=your_smtp_password
